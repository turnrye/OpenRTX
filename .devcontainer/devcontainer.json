{
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "BUILDKIT_STEP_LOG_MAX_SIZE": "10485760" // 10 MiB
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools-extension-pack",
        "ms-vscode.cmake-tools",
        "ms-python.python"
      ]
    }
  },
  "postCreateCommand": "cmake -B build_linux -DOPENRTX_TARGET=linux"
}
